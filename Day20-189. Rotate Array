class Solution {
public:
    void rotate(vector<int>& nums, int k) {
        int n=nums.size();
        k=k%n;//when k>n
        
        reverse(nums.begin(), nums.end());//Reversed the whole array
        reverse(nums.begin(), nums.begin()+k);//Left side reverse
        reverse(nums.begin()+k,nums.end());//Right side reverse
        
    }
};
