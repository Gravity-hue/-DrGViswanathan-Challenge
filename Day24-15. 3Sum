class Solution {
public:
    vector<vector<int>> threeSum(vector<int>& nums) {//2-pointer approach
        vector<vector<int>>ans;
        sort(nums.begin(),nums.end());

        for(int i=0; i<nums.size(); i++){
            if(i>0 &&nums[i]==nums[i-1])continue;//To skip the duplicates in sorted array to skip the addition of non unique value in ans

            int j=i+1;//value of i is fixed
            int k=nums.size()-1;

            while(j<k){
                int sum=nums[i]+nums[j]+nums[k];
                if(sum>0){
                    k--;
                }else if(sum<0){
                    j++;
                }else{
                    ans.push_back({nums[i],nums[j],nums[k]});
                    j++;
                    k--;

                    while(j<k && nums[j]==nums[j-1])j++;
                }
            }
        }
        return ans;
    }
};
