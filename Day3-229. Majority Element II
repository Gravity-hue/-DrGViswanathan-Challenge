class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
        vector<int>ans;
        unordered_map<int,int>frequencyCount;
        int n=nums.size();
        
        for(int i=0; i<n; i++){
           frequencyCount[nums[i]]++;
        }

        for(auto it: frequencyCount){
            if(it.second>n/3)ans.push_back(it.first);
        }

        return ans;
    }
};
