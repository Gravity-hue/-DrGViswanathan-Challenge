class Solution {
public:

long long calculateTime(vector<int>&nums, int h){
    long long totalTime=0;
    int n=nums.size();
    for(int i=0; i<n; i++){
        totalTime+=(nums[i]+h-1)/h;
    }
    return totalTime;
}

    int minEatingSpeed(vector<int>& piles, int h) {
     int n=piles.size();
     int minSpeed=INT_MAX;

     int maxx=piles[0];
     for(int i=1;i<n; i++){
        maxx=max(piles[i],maxx);
     }

     int low=1;
     int high=maxx;

     while(low<=high){
        int mid=low+(high-low)/2;
        long long time=calculateTime(piles,mid);
        if(time<=h){
            minSpeed=min(minSpeed,mid);
            high=mid-1;
        }else{
            low=mid+1;
        }
     }
     return minSpeed;
    }
};
